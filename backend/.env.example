# ── Database ─────────────────────────────────────
# SQLite (dev/demo — không cần cài thêm gì):
DATABASE_URL=sqlite:./database/edusmart.sqlite
# PostgreSQL (production / Supabase):
# DATABASE_URL=postgresql://user:pass@host:5432/edusmart

# ── Auth ─────────────────────────────────────────
JWT_SECRET=your_very_long_random_secret
JWT_REFRESH_SECRET=another_long_random_secret
JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES=7d

# ── AI (chọn một) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...   # Thay thế nếu dùng Gemini
AI_PROVIDER=anthropic

# ── Email SMTP ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=app_password_here
SMTP_FROM="EduSmart <no-reply@edusmart.local>"

# ── App ──────────────────────────────────────────
PORT=3001
# Local dev (mặc định). Production: https://your-app.vercel.app hoặc nhiều origin cách nhau bằng dấu phẩy
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
CURRENT_SCHOOL_YEAR=2024-2025

# ── Web Push (TKB học sinh) ─────────────────────
# Chạy: node scripts/generate-vapid-keys.js rồi dán vào .env
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@edusmart.local
# ENABLE_SCHEDULE_CRON=1
